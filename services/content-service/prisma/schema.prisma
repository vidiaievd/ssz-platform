generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ─── Enums ─────────────────────────────────────────────────────────────────
// Prisma enum identifiers are SCREAMING_SNAKE_CASE; DB values are lowercase
// via @map so application code always works with the Prisma representation.

enum ContainerType {
  COURSE     @map("course")
  MODULE     @map("module")
  COLLECTION @map("collection")

  @@map("container_type")
}

enum DifficultyLevel {
  A1
  A2
  B1
  B2
  C1
  C2

  @@map("difficulty_level")
}

enum Visibility {
  PUBLIC         @map("public")
  SCHOOL_PRIVATE @map("school_private")
  SHARED         @map("shared")
  PRIVATE        @map("private")

  @@map("visibility")
}

enum AccessTier {
  ASSIGNED_ONLY        @map("assigned_only")
  ENTITLEMENT_REQUIRED @map("entitlement_required")
  FREE_WITHIN_SCHOOL   @map("free_within_school")
  PUBLIC_FREE          @map("public_free")
  PUBLIC_PAID          @map("public_paid")

  @@map("access_tier")
}

enum VersionStatus {
  DRAFT      @map("draft")
  PUBLISHED  @map("published")
  DEPRECATED @map("deprecated")
  ARCHIVED   @map("archived")

  @@map("version_status")
}

enum ContainerItemType {
  CONTAINER       @map("container")
  LESSON          @map("lesson")
  VOCABULARY_LIST @map("vocabulary_list")
  GRAMMAR_RULE    @map("grammar_rule")
  EXERCISE        @map("exercise")

  @@map("container_item_type")
}

enum VariantStatus {
  DRAFT     @map("draft")
  PUBLISHED @map("published")

  @@map("variant_status")
}

enum MediaRefType {
  IMAGE @map("image")
  AUDIO @map("audio")
  VIDEO @map("video")

  @@map("media_ref_type")
}

// ─── Models ────────────────────────────────────────────────────────────────

// Container is an "idea" entity — metadata shell around versioned content.
// currentPublishedVersionId is intentionally NOT a Prisma @relation to avoid
// a circular dependency with ContainerVersion. A DEFERRABLE FK is added via
// raw SQL in the follow-up migration (add-container-constraints).
model Container {
  id                        String          @id @default(uuid()) @db.Uuid
  // Partial unique index on (slug) WHERE slug IS NOT NULL AND deleted_at IS NULL
  // is enforced via raw SQL — Prisma does not support partial unique indexes.
  slug                      String?         @db.VarChar(120)
  containerType             ContainerType   @map("container_type")
  targetLanguage            String          @map("target_language") @db.VarChar(10)
  difficultyLevel           DifficultyLevel @map("difficulty_level")
  title                     String          @db.VarChar(200)
  description               String?         @db.Text
  coverImageMediaId         String?         @map("cover_image_media_id") @db.Uuid
  ownerUserId               String          @map("owner_user_id") @db.Uuid
  ownerSchoolId             String?         @map("owner_school_id") @db.Uuid
  visibility                Visibility
  accessTier                AccessTier      @map("access_tier")
  // Raw FK to container_versions.id (DEFERRABLE INITIALLY DEFERRED) added via migration.
  currentPublishedVersionId String?         @map("current_published_version_id") @db.Uuid
  createdAt                 DateTime        @default(now()) @map("created_at") @db.Timestamptz
  updatedAt                 DateTime        @updatedAt @map("updated_at") @db.Timestamptz
  deletedAt                 DateTime?       @map("deleted_at") @db.Timestamptz

  versions      ContainerVersion[]
  localizations ContainerLocalization[]

  @@index([ownerUserId])
  @@index([ownerSchoolId])
  @@index([visibility])
  @@index([targetLanguage, difficultyLevel])
  @@index([deletedAt, visibility, targetLanguage])
  @@map("containers")
}

// One container can have many versions. Only one draft and one published version
// are allowed at a time — enforced via partial unique indexes in raw SQL migration.
model ContainerVersion {
  id                String        @id @default(uuid()) @db.Uuid
  containerId       String        @map("container_id") @db.Uuid
  versionNumber     Int           @map("version_number")
  status            VersionStatus
  changelog         String?       @db.Text
  createdAt         DateTime      @default(now()) @map("created_at") @db.Timestamptz
  createdByUserId   String        @map("created_by_user_id") @db.Uuid
  publishedAt       DateTime?     @map("published_at") @db.Timestamptz
  publishedByUserId String?       @map("published_by_user_id") @db.Uuid
  deprecatedAt      DateTime?     @map("deprecated_at") @db.Timestamptz
  sunsetAt          DateTime?     @map("sunset_at") @db.Timestamptz
  archivedAt        DateTime?     @map("archived_at") @db.Timestamptz
  // Incremented on every item mutation; used for optimistic concurrency on reorder.
  revisionCount     Int           @default(0) @map("revision_count")

  container Container      @relation(fields: [containerId], references: [id])
  items     ContainerItem[]

  @@unique([containerId, versionNumber])
  @@index([containerId])
  @@index([status, sunsetAt])
  @@map("container_versions")
}

// Ordered list of references inside a version. Position gaps are allowed after
// remove; reorder restores continuous numbering. Cascade-deleted with the version.
model ContainerItem {
  id                 String            @id @default(uuid()) @db.Uuid
  containerVersionId String            @map("container_version_id") @db.Uuid
  position           Int
  itemType           ContainerItemType @map("item_type")
  // Polymorphic reference — no Prisma relation; item_id is validated in application layer.
  itemId             String            @map("item_id") @db.Uuid
  isRequired         Boolean           @default(true) @map("is_required")
  sectionLabel       String?           @map("section_label") @db.VarChar(100)
  addedAt            DateTime          @default(now()) @map("added_at") @db.Timestamptz

  containerVersion ContainerVersion @relation(fields: [containerVersionId], references: [id], onDelete: Cascade)

  @@unique([containerVersionId, position])
  @@index([containerVersionId])
  @@index([itemType, itemId])
  @@map("container_items")
}

// Optional translated titles/descriptions for containers. One row per language.
model ContainerLocalization {
  id              String   @id @default(uuid()) @db.Uuid
  containerId     String   @map("container_id") @db.Uuid
  languageCode    String   @map("language_code") @db.VarChar(10)
  title           String   @db.VarChar(200)
  description     String?  @db.Text
  createdAt       DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt       DateTime @updatedAt @map("updated_at") @db.Timestamptz
  createdByUserId String   @map("created_by_user_id") @db.Uuid

  container Container @relation(fields: [containerId], references: [id], onDelete: Cascade)

  @@unique([containerId, languageCode])
  @@map("container_localizations")
}

// ─── Block 2: Lessons + Content Variants ──────────────────────────────────────

// Lesson is a language-neutral entity — metadata only. All student-facing
// content lives in LessonContentVariant (one per explanation_language × level_range).
// slug is NULL until the first variant is published for a public lesson;
// immutable after that. Partial unique index on slug is added via raw SQL migration.
model Lesson {
  id                String          @id @default(uuid()) @db.Uuid
  targetLanguage    String          @map("target_language") @db.VarChar(10)
  difficultyLevel   DifficultyLevel @map("difficulty_level")
  // Partial unique index: WHERE slug IS NOT NULL AND deleted_at IS NULL (raw SQL migration).
  slug              String?         @db.VarChar(120)
  title             String          @db.VarChar(200)
  description       String?         @db.Text
  coverImageMediaId String?         @map("cover_image_media_id") @db.Uuid
  ownerUserId       String          @map("owner_user_id") @db.Uuid
  ownerSchoolId     String?         @map("owner_school_id") @db.Uuid
  // CHECK constraint (raw SQL): owner_school_id IS NULL → visibility ∈ {public,shared,private}
  //                             owner_school_id IS NOT NULL → visibility ∈ {public,school_private,shared,private}
  visibility        Visibility
  createdAt         DateTime        @default(now()) @map("created_at") @db.Timestamptz
  updatedAt         DateTime        @updatedAt @map("updated_at") @db.Timestamptz
  deletedAt         DateTime?       @map("deleted_at") @db.Timestamptz

  variants LessonContentVariant[]

  @@index([ownerUserId])
  @@index([ownerSchoolId])
  @@index([visibility])
  @@index([targetLanguage, difficultyLevel])
  @@index([deletedAt, visibility, targetLanguage])
  @@map("lessons")
}

// One variant per (lesson_id, explanation_language, min_level, max_level) combination.
// Silent updates are allowed even when status = published (typo fixes, clarifications).
// deletedAt is set via cascade when the parent lesson is soft-deleted.
// Hard delete is used for direct DELETE /lessons/:id/variants/:vid requests.
model LessonContentVariant {
  id                      String        @id @default(uuid()) @db.Uuid
  lessonId                String        @map("lesson_id") @db.Uuid
  explanationLanguage     String        @map("explanation_language") @db.VarChar(10)
  minLevel                DifficultyLevel @map("min_level")
  maxLevel                DifficultyLevel @map("max_level")
  // CHECK constraint (raw SQL): ordinal(min_level) <= ordinal(max_level) via CASE mapping.
  displayTitle            String        @map("display_title") @db.VarChar(200)
  displayDescription      String?       @map("display_description") @db.Text
  bodyMarkdown            String        @map("body_markdown") @db.Text
  estimatedReadingMinutes Int?          @map("estimated_reading_minutes")
  status                  VariantStatus @default(DRAFT)
  createdAt               DateTime      @default(now()) @map("created_at") @db.Timestamptz
  updatedAt               DateTime      @updatedAt @map("updated_at") @db.Timestamptz
  createdByUserId         String        @map("created_by_user_id") @db.Uuid
  lastEditedByUserId      String        @map("last_edited_by_user_id") @db.Uuid
  publishedAt             DateTime?     @map("published_at") @db.Timestamptz
  // Set via bulk updateMany when parent lesson is soft-deleted.
  deletedAt               DateTime?     @map("deleted_at") @db.Timestamptz

  lesson    Lesson                 @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  mediaRefs LessonVariantMediaRef[]

  @@unique([lessonId, explanationLanguage, minLevel, maxLevel])
  @@index([lessonId])
  @@index([lessonId, status])
  @@map("lesson_content_variants")
}

// Denormalized table extracted from body_markdown on every save.
// Enables fast reverse lookups: "which lessons use media asset X?"
// Replaced atomically (delete+createMany in a transaction) on every variant save.
model LessonVariantMediaRef {
  id                     String       @id @default(uuid()) @db.Uuid
  lessonContentVariantId String       @map("lesson_content_variant_id") @db.Uuid
  mediaId                String       @map("media_id") @db.Uuid
  mediaType              MediaRefType @map("media_type")
  positionInText         Int          @map("position_in_text")
  extractedAt            DateTime     @map("extracted_at") @db.Timestamptz

  variant LessonContentVariant @relation(fields: [lessonContentVariantId], references: [id], onDelete: Cascade)

  @@index([lessonContentVariantId])
  @@index([mediaId])
  @@map("lesson_variant_media_refs")
}
