{
  "Logging": {
    "LogLevel": {
      "Default": "Debug",
      "Microsoft.AspNetCore": "Information",
      "Microsoft.EntityFrameworkCore.Database.Command": "Information",
      "Microsoft.EntityFrameworkCore.ChangeTracking": "Debug",
      "Microsoft.EntityFrameworkCore.Update": "Debug"
    }
  },
  "ConnectionStrings": {
    "Postgres": "Host=localhost;Port=5432;Database=auth_db;Username=auth_service;Password=auth_service_password",
    "Redis": "localhost:6379,password=localdevpassword"
  },
  "RabbitMq": {
    "Host": "localhost",
    "Port": 5672,
    "Username": "ssz_admin",
    "Password": "localdevpassword"
  },
  "Auth": {
    "Issuer": "https://auth.ssz-platform.internal",
    "Audience": "ssz-services",
    "PrivateKeyPath": "keys/jwt_private_key.pem",
    "PublicKeyPath": "keys/jwt_public_key.pem",
    "MfaChallengeSecret": "local-dev-secret-must-be-at-least-32-characters",
    "EncryptionKey": "AAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAA=",
    "TotpIssuer": "SSZPlatform",
    "AccessTokenLifetimeMinutes": 15,
    "RefreshTokenLifetimeDays": 7,
    "MfaChallengeLifetimeMinutes": 5,
    "MaxFailedLoginAttempts": 5,
    "LockoutDurationMinutes": 15
  }
